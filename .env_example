# Django Configuration
DJANGO_SECRET_KEY=your-django-secret-key-here
DEBUG=True
ENV_MODE=local
# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/database_name
PGDATABASE=your_database_name
PGUSER=your_database_user
PGPASSWORD=your_database_password
PGHOST=localhost
PGPORT=5432

# AI Service API Keys
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Email Configuration (for OTP and notifications)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-app-password
DEFAULT_FROM_EMAIL=noreply@yourapp.com

# SendGrid Email Service (optional alternative)
SENDGRID_API_KEY=your-sendgrid-api-key-here

# Redis Configuration (for caching and Celery)
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Cloud Storage Configuration (optional)
# AWS S3
CLOUD_STORAGE_S3_ACCESS_KEY=your-s3-access-key
CLOUD_STORAGE_S3_SECRET_KEY=your-s3-secret-key
S3_BUCKET_NAME=your-s3-bucket-name

# Google Cloud Storage
CLOUD_STORAGE_GCS_SERVICE_ACCOUNT_JSON={"type": "service_account", "project_id": "your-project"}
GCS_BUCKET_NAME=your-gcs-bucket-name

# Azure Storage
CLOUD_STORAGE_AZURE_ACCESS_KEY=your-azure-access-key
CLOUD_STORAGE_AZURE_SECRET_KEY=your-azure-secret-key

# Performance and Monitoring
ENABLE_PERFORMANCE_LOGGING=True
CACHE_TIMEOUT=3600

# Security Settings
CORS_ALLOW_ALL_ORIGINS=True
JWT_AUTH_SECURE=False
JWT_AUTH_HTTPONLY=False

# File Upload Limits
MAX_AUDIO_FILE_SIZE=10485760
MAX_IMAGE_FILE_SIZE=10485760

# Language Detection Settings
LANGUAGE_DETECTION_THRESHOLD=0.4

# Session Configuration
SESSION_COOKIE_AGE=86400
SESSION_SAVE_EVERY_REQUEST=True
